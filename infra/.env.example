# VPS / Docker Compose environment variables
# Copy this file to infra/.env and fill in real values (NEVER commit infra/.env)
# cp infra/.env.example infra/.env

# ─── NestJS API ───────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SYNC_API_KEY=
PORT=3001
NODE_ENV=production
RUN_MIGRATIONS_ON_START=true

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Get from: Cloudflare Zero Trust → Tunnels → your tunnel → token
CLOUDFLARE_TUNNEL_TOKEN=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=

# ─── Sentry (Backend) ─────────────────────────────────────────────────────────
# These go into your backend .env or VPS environment
SENTRY_DSN_BE=
SENTRY_PROJECT_BE=

# ─── GitHub (Backend Webhook) ────────────────────────────────────────────────
# Used by backend to create issues from Sentry alerts
# Must have 'repo' scope
GH_PAT=