# ─── API ──────────────────────────────────────────────────────────────────────
# Local dev: point to local NestJS API
NEXT_PUBLIC_API_URL=http://localhost:3005

# ─── Sentry (Frontend) ────────────────────────────────────────────────────────
# Get these from your Sentry project settings
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

NEXT_PUBLIC_ENV=development

# ─── Hermes sync auth (only needed if testing upsert routes locally) ──────────
# Must match SYNC_API_KEY in infra/.env
# SYNC_API_KEY=

